{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "types": ["jest", "@testing-library/jest-dom"],
    "paths": {
      "@common/*": ["../common/src/*"],
      "@private/*": ["../apps/private/src/*"],
      "@public/*": ["../apps/public/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "references": [
    { "path": "../common" },
    { "path": "../apps/private" },
    { "path": "../apps/public" }
  ]
}
