{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "paths": {
      "@/*": ["./src/*"],
      "@common/*": ["../../common/src/*"],
      "@injected/*": ["../../common/src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../../common" }]
}
